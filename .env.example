# .env.example - Configuration Template for Transcriptinator

# ============================================================================
# GOOGLE GEMINI CONFIGURATION (Required for Audio Transcription)
# ============================================================================
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT_ID=your_project_id_here

# Gemini Model (used for audio transcription - required)
GEMINI_MODEL=models/gemini-flash-latest
#GEMINI_MODEL=models/gemini-2.5-flash
#GEMINI_MODEL=models/gemini-3-flash-preview

# ============================================================================
# METADATA EXTRACTION PROVIDER CONFIGURATION
# ============================================================================
# Choose which AI provider to use for metadata extraction (summary, key ideas, concepts, etc.)
# Options: gemini, openrouter, groq
# Default: openrouter (recommended to avoid Gemini rate limits)
METADATA_PROVIDER=openrouter

# ----------------------------------------------------------------------------
# OpenRouter Configuration
# ----------------------------------------------------------------------------
# Sign up at: https://openrouter.ai/
# Free tier includes DeepSeek-R1 and other models
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-r1:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Other OpenRouter model options:
# - deepseek/deepseek-r1:free (recommended - free tier)
# - google/gemini-flash-1.5 (if you have credits)
# - anthropic/claude-3-haiku (fast and cheap)
# - meta-llama/llama-3.1-8b-instruct:free

# ----------------------------------------------------------------------------
# Groq Configuration
# ----------------------------------------------------------------------------
# Sign up at: https://console.groq.com/
# Free tier includes fast inference on various models
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Other Groq model options:
# - llama-3.3-70b-versatile (recommended - fast and accurate)
# - llama-3.1-70b-versatile
# - mixtral-8x7b-32768 (long context)
# - gemma2-9b-it (smaller, faster)

# ============================================================================
# USAGE NOTES
# ============================================================================
# 
# Audio Transcription (always uses Gemini):
#   - generate_transcription() - Requires Gemini for audio input
# 
# Metadata Extraction (configurable):
#   - extract_core_metadata() - Entities, concepts, relationships
#   - extract_cross_domain_insights() - Cross-domain connections
#   - generate_summary() - 2-3 sentence summary
#   - generate_key_ideas() - 3-5 key concepts
# 
# Rate Limit Strategy:
#   - Set METADATA_PROVIDER=openrouter to use free DeepSeek-R1
#   - Set METADATA_PROVIDER=groq for fast Llama inference
#   - Set METADATA_PROVIDER=gemini to use Gemini for everything (uses quota faster)
# 
# ============================================================================

# ============================================================================
# API RATE LIMITING CONFIGURATION
# ============================================================================
# Delays between metadata API calls (in seconds)
# Helps avoid rate limit errors (429) from providers like Groq
# 
# Groq llama-3.3-70b-versatile limits:
#   - 12,000 tokens per minute (TPM)
#   - Enhanced mode uses ~16,000 tokens (4 calls) → exceeds limit without delays
#
# Recommended delays for Groq: 5 seconds (adds ~15s total per file)
# For OpenRouter/Gemini: Set to 0 (no delays needed)

# Delay after core metadata extraction (Call #2)
METADATA_DELAY_AFTER_CORE=5

# Delay after cross-domain insights extraction (Call #3)
METADATA_DELAY_AFTER_CROSS_DOMAIN=5

# Delay after summary generation (Call #4)
METADATA_DELAY_AFTER_SUMMARY=5

# Global delay multiplier (adjust all delays proportionally)
# Example: 1.0 = normal, 2.0 = double all delays, 0.5 = half all delays, 0 = no delays
METADATA_DELAY_MULTIPLIER=1.0

# Enable/disable delay logging (shows "⏳ Rate limit delay: Xs..." messages)
METADATA_DELAY_LOGGING=true
